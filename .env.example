# Application
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Database (Supabase - to be configured)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# PIN Authentication
# Generate a random secret (e.g. openssl rand -hex 32) and store it here.
SESSION_SECRET=

# Hash your chosen PIN once with SESSION_SECRET, then store the output here.
# After setting SESSION_SECRET, run:
#   node -e "require('./src/lib/auth').hashPin('YOUR_PIN').then(h => console.log('PIN_HASH=' + h))"
# Example local test setup:
#   SESSION_SECRET=replace-with-a-random-secret
#   PIN_HASH=<hash for 1234 generated with the command above>
# The literal PIN is never stored in the repo or env file.
PIN_HASH=
